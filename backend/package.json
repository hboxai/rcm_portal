{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for claims management system",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:with-env": "tsx run-with-env.js",
    "prebuild": "node fix-imports.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/scripts/runMigrations.ts",
    "db:verify:uploads": "tsx src/scripts/verifyUploadsTable.ts",
    "db:verify:submit-cols": "tsx src/scripts/verifySubmitSystemCols.ts",
    "db:verify:reimburse-cols": "tsx src/scripts/verifyReimburseSystemCols.ts",
    "db:verify:submit-cpt-ids": "tsx src/scripts/verifySubmitCptIdCols.ts",
    "test:s3": "tsx src/scripts/s3ConnectivityTest.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:columns": "node scripts/list-columns.cjs api_bil_claim_submit",
    "db:seed:submit": "node scripts/seed-submit-table.cjs",
    "db:clear:submit": "tsx src/scripts/clearSubmitTable.ts",
    "purge:submit": "tsx src/scripts/purgeSubmitArtifacts.ts",
    "db:reset:full": "tsx src/scripts/purgeUploadsAndReset.ts",
    "reset:all": "tsx src/scripts/resetAllArtifacts.ts",
    "reimburse:mirror": "tsx src/scripts/reimburseMirror.ts",
    "reimburse:report": "tsx src/scripts/reimburseReport.ts",
    "diag:reimburse:seq": "tsx src/scripts/diagReimburseSequences.ts",
    "fix:reimburse:identity": "tsx src/scripts/fixReimburseIdentity.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "postgresql",
    "claims"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "backend": "^0.0.0",
    "bcryptjs": "^2.4.3",
    "cd": "^0.3.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf2json": "^4.0.0",
    "pg": "^8.10.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^18.19.103",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.20.3",
    "typescript": "^5.0.4"
  }
}
