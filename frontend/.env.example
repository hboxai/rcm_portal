# API Configuration
# The base URL for all API calls. Defaults to '/api' if not set.
# For local development with a separate backend, set this to your backend URL.
# Examples:
#   - /api (default, uses Vite proxy)
#   - http://localhost:5000/api (direct backend connection)
#   - https://api.example.com/api (production API)
VITE_API_BASE_URL=/api

# Environment
VITE_NODE_ENV=development