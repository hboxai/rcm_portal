{
  "name": "rcm-root",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:backend": "cd backend && powershell -ExecutionPolicy Bypass -File start-server.ps1",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "cd frontend && npm run build && cd ../backend && npm run build",
    "lint": "cd frontend && npm run lint",
    "preview": "cd frontend && npm run preview",
    "analyze:xls": "node scripts/analyze-excel.js",
    "docker:build": "docker-compose build",
    "docker:start": "docker-compose up",
    "docker:start:detached": "docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "devDependencies": {
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.15.2",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "backend": "^0.0.0",
    "bcrypt": "^6.0.0",
    "cd": "^0.3.3",
    "multer": "^2.0.0",
    "xlsx": "^0.18.5"
  }
}
